generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String           @id @default(cuid())
  email      String           @unique
  name       String?
  password   String
  campaigns  Campaign[]
  memberships CampaignMember[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model Campaign {
  id              String           @id @default(cuid())
  name            String
  description     String?
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id])
  members         CampaignMember[]
  startLevel      Int
  currentLevel    Int
  partySize       Int
  coinsOwedGp     Float            @default(0)
  permanentsOwed  Json             @default("[]")
  consumablesOwed Json             @default("[]")
  events          CampaignEvent[]
  sessions        Session[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model CampaignMember {
  id         String     @id @default(cuid())
  user       User       @relation(fields: [userId], references: [id])
  userId     String
  campaign   Campaign   @relation(fields: [campaignId], references: [id])
  campaignId String
  role       MemberRole
  joinedAt   DateTime   @default(now())
  leftAt     DateTime?

  @@unique([userId, campaignId])
}

enum MemberRole {
  GM
  PLAYER
}

model CampaignEvent {
  id            String    @id @default(cuid())
  campaign      Campaign  @relation(fields: [campaignId], references: [id])
  campaignId    String
  type          EventType
  fromLevel     Int?
  toLevel       Int?
  fromPartySize Int?
  toPartySize   Int?
  createdAt     DateTime  @default(now())
}

enum EventType {
  CAMPAIGN_CREATED
  LEVEL_UP
  PARTY_SIZE_CHANGE
}

model Session {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  date       DateTime
  notes      String?
  rewards    Reward[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Reward {
  id          String         @id @default(cuid())
  session     Session        @relation(fields: [sessionId], references: [id])
  sessionId   String
  description String
  category    RewardCategory
  itemLevel   Int?
  valueGp     Float?
  quantity    Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum RewardCategory {
  COINS
  PERMANENT
  CONSUMABLE
}
